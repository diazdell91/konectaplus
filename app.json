{
  "expo": {
    "name": "konectaplus",
    "slug": "konectaplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "konectaplus",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.konectaplus.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSContactsUsageDescription": "KonectaPlus usa tus contactos para que puedas recargar teléfonos rápidamente.",
        "NSCameraUsageDescription": "Permite escanear tu tarjeta de crédito o débito",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": true,
          "useHermesV1": true
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sqlite",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.konectaplus",
          "enableGooglePay": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear tu tarjeta de crédito o débito"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "419eca9f-5340-4308-b263-98f1b73bc546"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/419eca9f-5340-4308-b263-98f1b73bc546"
    }
  }
}
